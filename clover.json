  "components": {
    "schemas": {
      "EditRemarkReqDto": {
        "required": [
          "remarks"
        ],
        "type": "object",
        "properties": {
          "remarks": {
            "type": "string"
          }
        }
      },
      "Faculty": {
        "enum": [
          "ES",
          "CS",
          "MS",
          "BS",
          "DS",
          "HS"
        ]
      },
      "PcType": {
        "enum": [
          "Standard",
          "NonStandard"
        ]
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": [
              "null",
              "string"
            ]
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "StudentCountDto": {
        "required": [
          "totalCount"
        ],
        "type": "object",
        "properties": {
          "totalCount": {
            "type": "string"
          }
        }
      },
      "StudentDetailDto": {
        "required": [
          "id",
          "studentId",
          "name",
          "kanaName",
          "faculty",
          "pcType",
          "receptionAt",
          "isCheckedIn",
          "supply",
          "remarks",
          "checkInBlock",
          "createdAt",
          "updatedAt"
        ],
        "type": "object",
        "properties": {
          "id": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int64"
          },
          "studentId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "kanaName": {
            "type": "string"
          },
          "faculty": {
            "$ref": "#/components/schemas/Faculty"
          },
          "pcType": {
            "$ref": "#/components/schemas/PcType"
          },
          "receptionAt": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          },
          "isCheckedIn": {
            "type": "boolean"
          },
          "supply": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/SupplyDto"
              }
            ]
          },
          "remarks": {
            "type": [
              "null",
              "string"
            ]
          },
          "checkInBlock": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "SupplyDto": {
        "required": [
          "id",
          "name"
        ],
        "type": "object",
        "properties": {
          "id": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int64"
          },
          "name": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Student"
    }
  ]
}