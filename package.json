{
  "name": "new-student-reception-system",
  "version": "1.0.5",
  "description": "東京工科大学の新入生受付システムです。",
  "main": "./out/main/index.js",
  "author": "MediaLobby",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "generate": "openapi-typescript ./clover.json --enum --output ./src/main/api.ts"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "bootstrap": "^5.3.8",
    "classnames": "^2.5.1",
    "electron-updater": "^6.8.3",
    "howler": "^2.2.4",
    "jotai": "^2.18.0",
    "openapi-fetch": "^0.17.0",
    "react-icons": "^5.6.0",
    "react-modal": "^3.16.3",
    "sass": "^1.97.3",
    "sweetalert2": "^11.26.21",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/bootstrap": "^5.2.10",
    "@types/howler": "^2.2.12",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/xml2js": "^0.4.14",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.3",
    "eslint-plugin-react": "^7.37.5",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "local.mel-tut.new-student-reception-system",
    "productName": "新入生受付システム"
  }
}
